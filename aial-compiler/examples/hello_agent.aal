// Hello Agent — AAL 语言入门示例
// 展示：context 预算管理、ask 调用、字段访问、println

fn main() {
    // 创建上下文，设定 token 预算（"治未病"：编译器+运行时联合执法）
    let ctx = context::new(
        system_prompt = "你是助手",
        token_budget = 4096
    );

    // ask 是语言关键字，非库函数
    // model 0 = DeepSeek V4 Flash (default), 1 = DeepSeek V4 Pro, 2 = OpenAI GPT-4o
    let response = ask(
        model = 0,
        context = ctx,
        prompt = "你好！现在几点？",
        temperature = 0.7,
        max_tokens = 1024
    );

    // 字段访问提取 AI 回复文本
    println(response.text);
    return;
}
